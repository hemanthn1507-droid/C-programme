#include <stdio.h>

int main() {
    int n, i;
    int a = 0, b = 1, c, sum = 0;

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++) {
        sum = sum + a;
        c = a + b;
        a = b;
        b = c;
    }

    printf("Sum of Fibonacci series = %d", sum);

    return 0;
}
